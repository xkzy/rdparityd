// TestCategoryC_SingleBitFlipDetection verifies that a single bit flip in extent data
// is detected by scrub operation and marked as corrupted.
//
// VERIFICATION GOALS:
// - Scrub detects single-bit corruption in extent data
// - Corrupted extent ID matches the injected fault location
// - Scrub result reports FailedCount > 0
// - Checksum validation catches the bit flip
//
// FAILURE SCENARIOS:
// - Write file successfully, flip exactly 1 bit in extent data
// - Run scrub with repair disabled (audit-only mode)
//
// EXPECTED OUTCOMES:
// - Scrub detects corruption without attempting repair
// - FailedCount reports the corrupted extent
// - Healthy flag remains false until repair
func TestCategoryC_SingleBitFlipDetection(t *testing.T) {
	t.Skip("Category C not yet implemented: single-bit-flip detection needs checksum validation in scrub path")

	// PSEUDOCODE:
	// 1. Create coordinator and write file with known payload
	// 2. Locate extent file, read into memory
	// 3. Flip bit at offset (extentSize / 2) via data[offset] ^= (1 << 3)
	// 4. Write corrupted data back to disk
	// 5. Run coordinator.Scrub(false) for audit-only (no repair)
	// 6. Assert: result.FailedCount > 0
	// 7. Assert: extent appears in result.FailedExtentIDs
	// 8. Assert: result.Healthy == false

	root := t.TempDir()
	coordinator := NewCoordinator(
		filepath.Join(root, "metadata.json"),
		filepath.Join(root, "journal.log"),
	)

	// Implementation to follow
}

