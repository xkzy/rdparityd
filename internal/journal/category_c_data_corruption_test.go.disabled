	// 3. Concurrently write file2 and let it proceed to commit
	// 4. Corrupt file1 extent while scrub paused
	// 5. Resume scrub and let both complete
	// 6. Verify both files recover correctly

	root := t.TempDir()
	coordinator := NewCoordinator(
		filepath.Join(root, "metadata.json"),
		filepath.Join(root, "journal.log"),
	)

	// Implementation to follow
}

// TestCategoryC_CorruptionAfterCommit verifies that post-commit corruption
// (after transaction fully committed) is handled correctly on next scrub.
//
// VERIFICATION GOALS:
// - Post-commit corruption detected on next scrub
// - Committed transaction not replayed (no double-write)
