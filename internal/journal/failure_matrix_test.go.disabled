}

// TestA12_StateTransitionMetadataWrittenToCommitted: A12—no crash, clean
// commit. This is the happy path baseline for transition chain.
func TestA12_StateTransitionMetadataWrittenToCommitted(t *testing.T) {
	dir := t.TempDir()
	metadataPath := filepath.Join(dir, "metadata.json")
	journalPath := filepath.Join(dir, "journal.log")
	const payloadSize = (1 << 20) + 400
	payload := makePayload(payloadSize, 41)

	writeResult, err := NewCoordinator(metadataPath, journalPath).WriteFile(WriteRequest{
		PoolName:    "demo",
		LogicalPath: "/shares/test/a12.bin",
		Payload:     payload,
		// No FailAfter — full clean commit.
	})
	if err != nil {
		t.Fatalf("WriteFile: %v", err)
	}
	if writeResult.FinalState != StateCommitted {
		t.Fatalf("expected StateCommitted, got %s", writeResult.FinalState)
	}

	assertJournalClean(t, dir)
	assertInvariantsClean(t, dir)

	// Verify data round-trip.
	readResult, err := NewCoordinator(metadataPath, journalPath).ReadFile("/shares/test/a12.bin")
	if err != nil {
		t.Fatalf("ReadFile: %v", err)
	}
	if !bytes.Equal(readResult.Data, payload) {
		t.Fatal("data mismatch in A12")
	}
}

// TestA13_CrashAfterParityMetadataIntegrity: A13—crash after parity written
// but verify metadata integrity is maintained (parity is on disk, but metadata
// update may be partial). After recovery, all invariants must pass.
func TestA13_CrashAfterParityMetadataIntegrity(t *testing.T) {
	dir := t.TempDir()
	const payloadSize = (1 << 20) + 500
	payload := makePayload(payloadSize, 43)

	_, recoveryResult := crashAndRecover(
		t, dir, "/shares/test/a13.bin", payload, 0, StateParityWritten,
	)

	if len(recoveryResult.RecoveredTxIDs) != 1 {
		t.Fatalf("expected 1 recovered tx, got %v", recoveryResult.RecoveredTxIDs)
	}

	assertJournalClean(t, dir)
	assertInvariantsClean(t, dir)

	// Verify parity files exist and are correct (no corruption).
	metadataPath := filepath.Join(dir, "metadata.json")
	state, err := metadata.NewStore(metadataPath).Load()
	if err != nil {
		t.Fatalf("metadata.Load: %v", err)
	}
	if len(state.ParityGroups) == 0 {
		t.Fatalf("expected parity groups after A13 recovery, got none")
	}

	// Verify no parity violations.
	parityViolations := CheckIntegrityInvariants(dir, state)
	for _, v := range parityViolations {
		if v.Kind == "parity" {
			t.Errorf("unexpected parity violation after A13: %s", v.Error())
		}
	}
}

// TestA14_CrashAfterMetadataDataIntegrity: A14—crash after metadata written
// but before committed. Verify data extents remain intact and correct, parity
// is consistent, and recovery completes the transaction.
func TestA14_CrashAfterMetadataDataIntegrity(t *testing.T) {
	dir := t.TempDir()
	const payloadSize = (1 << 20) + 600
	payload := makePayload(payloadSize, 47)

	_, recoveryResult := crashAndRecover(
		t, dir, "/shares/test/a14.bin", payload, 0, StateMetadataWritten,
	)

	if len(recoveryResult.RecoveredTxIDs) != 1 {
		t.Fatalf("expected 1 recovered tx, got %v", recoveryResult.RecoveredTxIDs)
	}

	assertJournalClean(t, dir)
	assertInvariantsClean(t, dir)

	// Verify data extents have correct checksums.
	metadataPath := filepath.Join(dir, "metadata.json")
	journalPath := filepath.Join(dir, "journal.log")
	state, err := metadata.NewStore(metadataPath).Load()
	if err != nil {
		t.Fatalf("metadata.Load: %v", err)
	}

	// Find the file created in this test.
	var fileRec *metadata.FileRecord
	for i, f := range state.Files {
		if f.Path == "/shares/test/a14.bin" {
			fileRec = &state.Files[i]
			break
		}
	}
	if fileRec == nil {
		t.Fatalf("file not found in metadata after A14 recovery")
	}

	// Verify file can be read back correctly.
	readResult, err := NewCoordinator(metadataPath, journalPath).ReadFile("/shares/test/a14.bin")
	if err != nil {
		t.Fatalf("ReadFile: %v", err)
	}
	if !readResult.Verified {
		t.Errorf("expected verified=true after A14 recovery")
	}
	if !bytes.Equal(readResult.Data, payload) {
		t.Fatal("data mismatch in A14")
	}
}

// ─── Comprehensive crash matrix: all states × payload sizes ──────────────────

// TestAllCategoryACrashPoints: Table-driven test combining all crash points
// (A1-A14) with various payload sizes. For each combination, verify:
//   1. Recovery completes without error.
//   2. All invariants pass (E1-E3, P1-P4, M1-M3, J1-J3).
//   3. Recoverable states produce correct data round-trip.
type categoryATestCase struct {
	name       string
	payloadLen int
	crashState State
	// Whether to expect the transaction in RecoveredTxIDs (true) or
	// AbortedTxIDs (false). Prepared-only crashes abort; all others recover.
	expectRecovered bool
	// Whether the transaction produces a readable file after recovery.
	expectReadable bool
}

var categoryATestCases = []categoryATestCase{
	// A1: empty journal (tested separately in TestA1_EmptyJournalNoPrepareRecord)

	// A2-A3: prepared crash (abort)
	{"A2-prepared-512b", 512, StatePrepared, false, false},
	{"A3-prepared-1mib", 1 << 20, StatePrepared, false, false},

	// A4: mid-extent crash (tested separately in TestA4_CrashMidDataWriteExtentLimit1)

	// A6: data-written crash (recover)
	{"A6-data-written-512b", 512, StateDataWritten, true, true},
	{"A6-data-written-1mib", 1 << 20, StateDataWritten, true, true},
	{"A6-data-written-2mib", 2 << 20, StateDataWritten, true, true},

	// A7: mid-parity crash (tested separately in TestA7_CrashMidParityWriteParityLimit1)

	// A9-A12: state transitions (each tested separately above)

	// A13-A14: parity/metadata integrity (each tested separately above)
}

func TestAllCategoryACrashPoints(t *testing.T) {
	for _, tc := range categoryATestCases {
		tc := tc
		t.Run(tc.name, func(t *testing.T) {
			t.Parallel()
			dir := t.TempDir()
			metadataPath := filepath.Join(dir, "metadata.json")
			journalPath := filepath.Join(dir, "journal.log")

			payload := makePayload(tc.payloadLen, 53)
			_, err := NewCoordinator(metadataPath, journalPath).WriteFile(WriteRequest{
				PoolName:    "demo",
				LogicalPath: "/shares/test/" + tc.name + ".bin",
				Payload:     payload,
				FailAfter:   tc.crashState,
			})
			if err != nil {
				t.Fatalf("WriteFile: %v", err)
			}

			recoveryResult, err := NewCoordinator(metadataPath, journalPath).Recover()
			if err != nil {
				t.Fatalf("Recover: %v", err)
			}

			// Verify recovery split.
			if tc.expectRecovered {
				if len(recoveryResult.RecoveredTxIDs) == 0 {
					t.Fatalf("expected recovered tx, got none: %+v", recoveryResult)
				}
			} else {
				if len(recoveryResult.AbortedTxIDs) == 0 {
					t.Fatalf("expected aborted tx, got none: %+v", recoveryResult)
				}
			}

			assertJournalClean(t, dir)
			assertInvariantsClean(t, dir)

			// Verify data round-trip for readable states.
			if !tc.expectReadable {
				return
			}

			readResult, err := NewCoordinator(metadataPath, journalPath).ReadFile("/shares/test/" + tc.name + ".bin")
			if err != nil {
				t.Fatalf("ReadFile: %v", err)
			}
			if !bytes.Equal(readResult.Data, payload) {
				t.Fatalf("data mismatch in %s", tc.name)
			}
		})
	}
}

// ─── Recovery idempotency: double-recovery test ──────────────────────────────

// TestA_RecoveryIdempotentAfterCrash: Verify that calling Recover() twice
// produces the same system state. This is critical for robustness during system
// restarts or retry scenarios.
func TestA_RecoveryIdempotentAfterCrash(t *testing.T) {
	dir := t.TempDir()
	metadataPath := filepath.Join(dir, "metadata.json")
	journalPath := filepath.Join(dir, "journal.log")
	payload := makePayload((1<<20)+100, 59)

	// Crash at data-written.
	_, err := NewCoordinator(metadataPath, journalPath).WriteFile(WriteRequest{
		PoolName:    "demo",
		LogicalPath: "/shares/test/idempotent.bin",
		Payload:     payload,
		FailAfter:   StateDataWritten,
	})
	if err != nil {
		t.Fatalf("WriteFile: %v", err)
	}

	// First recovery.
	result1, err := NewCoordinator(metadataPath, journalPath).Recover()
	if err != nil {
		t.Fatalf("first Recover: %v", err)
	}

	// Second recovery — must be a no-op.
	result2, err := NewCoordinator(metadataPath, journalPath).Recover()
	if err != nil {
		t.Fatalf("second Recover: %v", err)
	}

	// Both recoveries should report the same transaction counts.
	if len(result1.RecoveredTxIDs) != len(result2.RecoveredTxIDs) {
		t.Fatalf("recovered tx counts differ: first=%d second=%d",
			len(result1.RecoveredTxIDs), len(result2.RecoveredTxIDs))
	}
	if len(result1.AbortedTxIDs) != len(result2.AbortedTxIDs) {
		t.Fatalf("aborted tx counts differ: first=%d second=%d",
			len(result1.AbortedTxIDs), len(result2.AbortedTxIDs))
	}

	assertJournalClean(t, dir)
	assertInvariantsClean(t, dir)

	// Data must still be correct.
	readResult, err := NewCoordinator(metadataPath, journalPath).ReadFile("/shares/test/idempotent.bin")
	if err != nil {
		t.Fatalf("ReadFile after double recovery: %v", err)
	}
	if !bytes.Equal(readResult.Data, payload) {
		t.Fatal("data mismatch after double recovery")
	}
}

// TestA_MultipleCrashedWritesRecoveredTogether: Verify a single Recover() call
// handles multiple crashed transactions simultaneously. First transaction
// crashes at prepared (abort), second crashes at parity-written (recover).
// Both must be handled correctly in one recovery pass.
func TestA_MultipleCrashedWritesRecoveredTogether(t *testing.T) {
	dir := t.TempDir()
	metadataPath := filepath.Join(dir, "metadata.json")
	journalPath := filepath.Join(dir, "journal.log")

	// Baseline: committed write to prime the system.
	basePayload := makePayload((1 << 20), 61)
	baseResult, err := NewCoordinator(metadataPath, journalPath).WriteFile(WriteRequest{
		PoolName:    "demo",
		LogicalPath: "/shares/multi/base.bin",
		Payload:     basePayload,
	})
	if err != nil || baseResult.FinalState != StateCommitted {
		t.Fatalf("baseline WriteFile: err=%v state=%s", err, baseResult.FinalState)
	}

	// First crash: prepared only (abort).
	payloadA := makePayload((1<<20)+100, 67)
	_, err = NewCoordinator(metadataPath, journalPath).WriteFile(WriteRequest{
		PoolName:    "demo",
		LogicalPath: "/shares/multi/a.bin",
		Payload:     payloadA,
		FailAfter:   StatePrepared,
	})
	if err != nil {
		t.Fatalf("crash write A: %v", err)
	}

	// Second crash: parity-written (recover).
	payloadB := makePayload((1<<20)+200, 71)
	_, err = NewCoordinator(metadataPath, journalPath).WriteFile(WriteRequest{
		PoolName:    "demo",
		LogicalPath: "/shares/multi/b.bin",
		Payload:     payloadB,
		FailAfter:   StateParityWritten,
	})
	if err != nil {
		t.Fatalf("crash write B: %v", err)
	}

	// Single Recover().
	result, err := NewCoordinator(metadataPath, journalPath).Recover()
	if err != nil {
		t.Fatalf("Recover: %v", err)
	}
	if len(result.RecoveredTxIDs) != 1 {
		t.Errorf("expected 1 recovered tx, got %v", result.RecoveredTxIDs)
	}
	if len(result.AbortedTxIDs) != 1 {
		t.Errorf("expected 1 aborted tx, got %v", result.AbortedTxIDs)
	}

	assertJournalClean(t, dir)
	assertInvariantsClean(t, dir)

	// Verify all files.
	coordinator := NewCoordinator(metadataPath, journalPath)

	readBase, err := coordinator.ReadFile("/shares/multi/base.bin")
	if err != nil {
		t.Fatalf("ReadFile base.bin: %v", err)
	}
	if !bytes.Equal(readBase.Data, basePayload) {
		t.Fatal("base.bin corrupted")
	}

	readB, err := coordinator.ReadFile("/shares/multi/b.bin")
	if err != nil {
		t.Fatalf("ReadFile b.bin: %v", err)
	}
	if !bytes.Equal(readB.Data, payloadB) {
		t.Fatal("b.bin corrupted")
	}

	// a.bin must not exist.
	if _, err := coordinator.ReadFile("/shares/multi/a.bin"); err == nil {
		t.Fatal("expected a.bin to not exist after abort")
	}
}
