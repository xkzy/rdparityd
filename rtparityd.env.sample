# rtparityd runtime environment
# Copy to /etc/rtparityd/rtparityd.env and source before starting daemon

export RTPARITYD_SOCKET=/var/run/rtparityd/rtparityd.sock
export RTPARITYD_ADMIN_SOCKET=/var/run/rtparityd/rtparityd-admin.sock
export RTPARITYD_PID_FILE=/var/run/rtparityd/rtparityd.pid
export RTPARITYD_JOURNAL_PATH=/var/lib/rtparityd/journal.bin
export RTPARITYD_METADATA_PATH=/var/lib/rtparityd/metadata.bin
export RTPARITYD_CONFIG=/etc/rtparityd/rtparityd.conf
export RTPARITYD_LOG_LEVEL=info
export RTPARITYD_LOG_JSON=true
